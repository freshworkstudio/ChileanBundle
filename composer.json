{
  "name": "freshwork/chilean-bundle",
  "description": "A PHP composer package with Chilean validations, common variables, etc. (RUT, IVA, ETC). Ready for Laravel. Grande chile ctm :)",
  "authors": [
    {
      "name": "Gonzalo De Spirito | Freshwork Studio Chile",
      "email": "gonzalo@freshworkstudio.com"
    }
  ],
  "keywords": [
    "chile",
    "rut",
    "freshwork",
    "validation",
    "tools",
    "laravel"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "laravel/pint": "^1.13",
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest": "^3.0",
    "phpstan/phpstan": "^2.0",
    "rector/rector": "^2.0"
  },
  "suggest": {
    "illuminate/support": "Required to use the Laravel integration (validation rule, facade and cast)."
  },
  "autoload": {
    "psr-4": {
      "Freshwork\\ChileanBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Freshwork\\ChileanBundle\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest",
    "lint": "pint --test",
    "fix": "pint",
    "analyse": "phpstan analyse"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Freshwork\\ChileanBundle\\Laravel\\ChileanBundleServiceProvider"
      ],
      "aliases": {
        "Rut": "Freshwork\\ChileanBundle\\Facades\\Rut"
      }
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
